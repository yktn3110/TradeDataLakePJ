      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN pnl > 0 THEN 1 ELSE 0 END) / COUNT(*), 1) as value FROM trades_view WHERE trade_date BETWEEN '${__from:date:YYYY-MM-DD}' AND '${__to:date:YYYY-MM-DD}' AND stock_code IN ($stock_code) AND ('$category' = 'All' OR trade_category = '$category') AND ('$trade_type' = 'All' OR trade_type = '$trade_type')", "format": "table", "refId": "A"}]
