{
  "uid": "daytrade-v1",
  "title": "デイトレ損益ダッシュボード",
  "description": "デイトレ（時間付き）損益分析",
  "tags": ["daytrade"],
  "timezone": "Asia/Tokyo",
  "schemaVersion": 38,
  "version": 30,
  "refresh": "",
  "graphTooltip": 1,
  "time": {"from": "now/d+9h", "to": "now/d-8h"},
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "trade_date",
        "label": "日付",
        "datasource": {"type": "mysql", "uid": "trade-mysql"},
        "query": "SELECT DISTINCT DATE_FORMAT(trade_date, '%Y-%m-%d') AS trade_date FROM daytrades ORDER BY trade_date DESC",
        "current": {},
        "multi": false,
        "includeAll": false,
        "refresh": 2,
        "sort": 0,
        "hide": 0
      },
      {
        "type": "query",
        "name": "stock_code",
        "label": "銘柄",
        "datasource": {"type": "mysql", "uid": "trade-mysql"},
        "query": "SELECT stock_name AS __text, stock_code AS __value FROM (SELECT DISTINCT stock_code, stock_name FROM daytrades WHERE trade_date = '$trade_date') t ORDER BY stock_code",
        "current": {},
        "multi": true,
        "includeAll": true,
        "refresh": 2,
        "sort": 1,
        "hide": 0
      },
      {
        "type": "custom",
        "name": "side",
        "label": "取引方向",
        "query": "All,LONG,SHORT",
        "options": [
          {"text": "All",   "value": "All",   "selected": true},
          {"text": "LONG",  "value": "LONG",  "selected": false},
          {"text": "SHORT", "value": "SHORT", "selected": false}
        ],
        "current": {"text": "All", "value": "All"},
        "multi": false,
        "includeAll": false,
        "hide": 0
      },
      {
        "type": "query",
        "name": "chart_code",
        "label": "チャート銘柄",
        "datasource": {"type": "mysql", "uid": "trade-mysql"},
        "query": "SELECT CONCAT(stock_code, ' ', stock_name) AS __text, stock_code AS __value FROM (SELECT DISTINCT stock_code, stock_name FROM daytrades WHERE trade_date = '$trade_date') t ORDER BY stock_code",
        "current": {},
        "multi": false,
        "includeAll": false,
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "annotations": {"list": []},
  "links": [
    {"title": "CSVアップロード", "url": "http://localhost:8000", "icon": "external link", "targetBlank": true, "type": "link", "tooltip": "デイトレ xlsx をインポート"},
    {"title": "⏱ 9:00-15:30 リセット", "url": "/d/daytrade-v1?from=now%2Fd%2B9h&to=now%2Fd-8h&orgId=1&timezone=Asia%2FTokyo", "icon": "clock-o", "targetBlank": false, "type": "link", "tooltip": "ズームを 9:00-15:30 にリセット"}
  ],
  "panels": [
    {
      "id": 100, "type": "row", "title": "サマリー",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false, "panels": []
    },
    {
      "id": 1, "type": "stat", "title": "総損益",
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 3},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {"defaults": {"unit": "locale", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "#f2495c", "value": null}, {"color": "#73bf69", "value": 0}]}}},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT SUM(pnl) AS value FROM daytrades WHERE trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side')", "refId": "A"}]
    },
    {
      "id": 2, "type": "stat", "title": "トレード数",
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 3},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"fixedColor": "#5794f2", "mode": "fixed"}}},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT COUNT(*) AS value FROM daytrades WHERE trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side')", "refId": "A"}]
    },
    {
      "id": 3, "type": "stat", "title": "勝率",
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 3},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "#f2495c", "value": null}, {"color": "#ff9830", "value": 50}, {"color": "#73bf69", "value": 60}]}}},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN pnl > 0 THEN 1 ELSE 0 END) / COUNT(*), 1) AS value FROM daytrades WHERE trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side')", "refId": "A"}]
    },
    {
      "id": 4, "type": "stat", "title": "プロフィットファクター",
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 3},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {"defaults": {"decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "#f2495c", "value": null}, {"color": "#ff9830", "value": 1}, {"color": "#73bf69", "value": 1.5}]}}},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT ROUND(SUM(CASE WHEN pnl > 0 THEN pnl ELSE 0 END) / NULLIF(ABS(SUM(CASE WHEN pnl < 0 THEN pnl ELSE 0 END)), 0), 2) AS value FROM daytrades WHERE trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side')", "refId": "A"}]
    },
    {
      "id": 5, "type": "stat", "title": "平均利益",
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 3},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {"defaults": {"unit": "locale", "color": {"fixedColor": "#73bf69", "mode": "fixed"}}},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT ROUND(AVG(pnl)) AS value FROM daytrades WHERE pnl > 0 AND trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side')", "refId": "A"}]
    },
    {
      "id": 6, "type": "stat", "title": "平均損失",
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 3},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {"defaults": {"unit": "locale", "color": {"fixedColor": "#f2495c", "mode": "fixed"}}},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT ROUND(AVG(pnl)) AS value FROM daytrades WHERE pnl < 0 AND trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side')", "refId": "A"}]
    },
    {
      "id": 101, "type": "row", "title": "時系列分析",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 1},
      "collapsed": false, "panels": []
    },
    {
      "id": 7, "type": "timeseries", "title": "累計損益の推移",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 9},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 3, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "always", "pointSize": 6}
        },
        "overrides": [{"matcher": {"id": "byName", "options": "cum_pnl"}, "properties": [
          {"id": "displayName", "value": "累計損益"},
          {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "#f2495c", "value": null}, {"color": "#73bf69", "value": 0}]}},
          {"id": "color", "value": {"mode": "thresholds"}}
        ]}]
      },
      "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "time_series", "rawSql": "SELECT CONVERT_TZ(exit_at, '+09:00', '+00:00') + INTERVAL DATEDIFF(DATE(DATE_ADD(UTC_TIMESTAMP(), INTERVAL 9 HOUR)), '$trade_date') DAY AS time, SUM(pnl) OVER (ORDER BY exit_at ROWS UNBOUNDED PRECEDING) AS cum_pnl FROM daytrades WHERE trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side') ORDER BY exit_at", "refId": "A"}]
    },
    {
      "id": 104, "type": "row", "title": "チャート分析",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1},
      "collapsed": false, "panels": []
    },
    {
      "id": 20, "type": "candlestick", "title": "ローソク足チャート（$chart_code）",
      "gridPos": {"x": 0, "y": 15, "w": 24, "h": 12},
      "datasource": {"type": "datasource", "uid": "-- Mixed --"},
      "fieldConfig": {
        "defaults": {"unit": "locale"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "LONG買い"},
            "properties": [
              {"id": "custom.drawStyle", "value": "points"},
              {"id": "custom.showPoints", "value": "always"},
              {"id": "custom.pointSize", "value": 14},
              {"id": "custom.lineWidth", "value": 0},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#00E090"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "LONG売り"},
            "properties": [
              {"id": "custom.drawStyle", "value": "points"},
              {"id": "custom.showPoints", "value": "always"},
              {"id": "custom.pointSize", "value": 14},
              {"id": "custom.lineWidth", "value": 0},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#FF9830"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "SHORT売り"},
            "properties": [
              {"id": "custom.drawStyle", "value": "points"},
              {"id": "custom.showPoints", "value": "always"},
              {"id": "custom.pointSize", "value": 14},
              {"id": "custom.lineWidth", "value": 0},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#F2495C"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "SHORT買戻し"},
            "properties": [
              {"id": "custom.drawStyle", "value": "points"},
              {"id": "custom.showPoints", "value": "always"},
              {"id": "custom.pointSize", "value": 14},
              {"id": "custom.lineWidth", "value": 0},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#5794F2"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "株数"},
            "properties": [
              {"id": "custom.hideFrom", "value": {"viz": false, "legend": true, "tooltip": false}},
              {"id": "custom.drawStyle", "value": "points"},
              {"id": "custom.showPoints", "value": "always"},
              {"id": "custom.pointSize", "value": 1},
              {"id": "custom.lineWidth", "value": 0},
              {"id": "custom.axisPlacement", "value": "hidden"},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "transparent"}},
              {"id": "unit", "value": "short"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "損益"},
            "properties": [
              {"id": "custom.hideFrom", "value": {"viz": false, "legend": true, "tooltip": false}},
              {"id": "custom.drawStyle", "value": "points"},
              {"id": "custom.showPoints", "value": "always"},
              {"id": "custom.pointSize", "value": 1},
              {"id": "custom.lineWidth", "value": 0},
              {"id": "custom.axisPlacement", "value": "hidden"},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "transparent"}},
              {"id": "unit", "value": "locale"}
            ]
          }
        ]
      },
      "options": {
        "mode": "candles",
        "candleStyle": "candles",
        "colorStrategy": "open-close",
        "upColor": "red",
        "downColor": "dark-blue",
        "openClosePair": {},
        "includeAllFields": true,
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://api:8000/api/ohlcv?code=${chart_code}&date=${trade_date}",
          "url_options": {"method": "GET", "data": ""},
          "parser": "backend",
          "format": "table",
          "root_selector": "",
          "columns": [
            {"selector": "time", "text": "time", "type": "timestamp"},
            {"selector": "open",  "text": "open",  "type": "number"},
            {"selector": "high",  "text": "high",  "type": "number"},
            {"selector": "low",   "text": "low",   "type": "number"},
            {"selector": "close", "text": "close", "type": "number"}
          ]
        },
        {
          "datasource": {"type": "mysql", "uid": "trade-mysql"},
          "refId": "B",
          "format": "time_series",
          "rawSql": "SELECT CONVERT_TZ(entry_at, '+09:00', '+00:00') + INTERVAL DATEDIFF(DATE(DATE_ADD(UTC_TIMESTAMP(), INTERVAL 9 HOUR)), '$trade_date') DAY AS time, entry_price AS `LONG買い`, quantity AS 株数 FROM daytrades WHERE trade_date = '$trade_date' AND stock_code = '$chart_code' AND side = 'LONG' AND ('$side' = 'All' OR side = '$side') ORDER BY entry_at"
        },
        {
          "datasource": {"type": "mysql", "uid": "trade-mysql"},
          "refId": "C",
          "format": "time_series",
          "rawSql": "SELECT CONVERT_TZ(exit_at, '+09:00', '+00:00') + INTERVAL DATEDIFF(DATE(DATE_ADD(UTC_TIMESTAMP(), INTERVAL 9 HOUR)), '$trade_date') DAY AS time, exit_price AS `LONG売り`, quantity AS 株数, pnl AS 損益 FROM daytrades WHERE trade_date = '$trade_date' AND stock_code = '$chart_code' AND side = 'LONG' AND ('$side' = 'All' OR side = '$side') ORDER BY exit_at"
        },
        {
          "datasource": {"type": "mysql", "uid": "trade-mysql"},
          "refId": "D",
          "format": "time_series",
          "rawSql": "SELECT CONVERT_TZ(entry_at, '+09:00', '+00:00') + INTERVAL DATEDIFF(DATE(DATE_ADD(UTC_TIMESTAMP(), INTERVAL 9 HOUR)), '$trade_date') DAY AS time, entry_price AS `SHORT売り`, quantity AS 株数 FROM daytrades WHERE trade_date = '$trade_date' AND stock_code = '$chart_code' AND side = 'SHORT' AND ('$side' = 'All' OR side = '$side') ORDER BY entry_at"
        },
        {
          "datasource": {"type": "mysql", "uid": "trade-mysql"},
          "refId": "E",
          "format": "time_series",
          "rawSql": "SELECT CONVERT_TZ(exit_at, '+09:00', '+00:00') + INTERVAL DATEDIFF(DATE(DATE_ADD(UTC_TIMESTAMP(), INTERVAL 9 HOUR)), '$trade_date') DAY AS time, exit_price AS `SHORT買戻し`, quantity AS 株数, pnl AS 損益 FROM daytrades WHERE trade_date = '$trade_date' AND stock_code = '$chart_code' AND side = 'SHORT' AND ('$side' = 'All' OR side = '$side') ORDER BY exit_at"
        }
      ]
    },
    {
      "id": 102, "type": "row", "title": "銘柄・種別分析",
      "gridPos": {"x": 0, "y": 27, "w": 24, "h": 1},
      "collapsed": false, "panels": []
    },
    {
      "id": 8, "type": "barchart", "title": "銘柄別損益",
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 9},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {
        "defaults": {"unit": "locale"},
        "overrides": [{"matcher": {"id": "byName", "options": "損益"}, "properties": [
          {"id": "custom.thresholdsStyle", "value": {"mode": "bar"}},
          {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "#f2495c", "value": null}, {"color": "#73bf69", "value": 0}]}},
          {"id": "color", "value": {"mode": "thresholds"}}
        ]}]
      },
      "options": {"xField": "銘柄", "orientation": "horizontal", "groupWidth": 0.7, "barWidth": 0.8, "tooltip": {"mode": "single"}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT CONCAT(stock_code, ' ', stock_name) AS 銘柄, SUM(pnl) AS 損益 FROM daytrades WHERE trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side') GROUP BY stock_code, stock_name ORDER BY 損益 DESC LIMIT 20", "refId": "A"}]
    },
    {
      "id": 9, "type": "barchart", "title": "取引方向別損益（LONG / SHORT）",
      "gridPos": {"x": 12, "y": 28, "w": 6, "h": 9},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {
        "defaults": {"unit": "locale"},
        "overrides": [{"matcher": {"id": "byName", "options": "損益"}, "properties": [
          {"id": "custom.thresholdsStyle", "value": {"mode": "bar"}},
          {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "#f2495c", "value": null}, {"color": "#73bf69", "value": 0}]}},
          {"id": "color", "value": {"mode": "thresholds"}}
        ]}]
      },
      "options": {"xField": "取引方向", "orientation": "auto", "groupWidth": 0.7, "barWidth": 0.6, "tooltip": {"mode": "single"}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT side AS 取引方向, SUM(pnl) AS 損益 FROM daytrades WHERE trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side') GROUP BY side ORDER BY 損益 DESC", "refId": "A"}]
    },
    {
      "id": 10, "type": "barchart", "title": "保有時間分布",
      "gridPos": {"x": 18, "y": 28, "w": 6, "h": 9},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": [{"matcher": {"id": "byName", "options": "件数"}, "properties": [
          {"id": "custom.thresholdsStyle", "value": {"mode": "bar"}},
          {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "#5794f2", "value": null}]}},
          {"id": "color", "value": {"mode": "thresholds"}}
        ]}]
      },
      "options": {"xField": "保有時間", "orientation": "auto", "groupWidth": 0.7, "barWidth": 0.8, "tooltip": {"mode": "single"}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT CASE WHEN duration_sec < 60 THEN '1分未満' WHEN duration_sec < 300 THEN '1-5分' WHEN duration_sec < 900 THEN '5-15分' WHEN duration_sec < 1800 THEN '15-30分' WHEN duration_sec < 3600 THEN '30-60分' ELSE '1時間超' END AS 保有時間, COUNT(*) AS 件数 FROM daytrades WHERE trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side') GROUP BY 保有時間 ORDER BY MIN(duration_sec)", "refId": "A"}]
    },
    {
      "id": 103, "type": "row", "title": "トレード明細",
      "gridPos": {"x": 0, "y": 37, "w": 24, "h": 1},
      "collapsed": false, "panels": []
    },
    {
      "id": 11, "type": "table", "title": "トレード明細",
      "gridPos": {"x": 0, "y": 38, "w": 24, "h": 10},
      "datasource": {"type": "mysql", "uid": "trade-mysql"},
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "pnl"},          "properties": [{"id": "displayName", "value": "損益"}, {"id": "unit", "value": "locale"}, {"id": "custom.displayMode", "value": "color-text"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "#f2495c", "value": null}, {"color": "#73bf69", "value": 0}]}}, {"id": "color", "value": {"mode": "thresholds"}}]},
          {"matcher": {"id": "byName", "options": "trade_date"},   "properties": [{"id": "displayName", "value": "日付"}]},
          {"matcher": {"id": "byName", "options": "entry_at"},     "properties": [{"id": "displayName", "value": "エントリー"}]},
          {"matcher": {"id": "byName", "options": "exit_at"},      "properties": [{"id": "displayName", "value": "エグジット"}]},
          {"matcher": {"id": "byName", "options": "duration_sec"}, "properties": [{"id": "displayName", "value": "保有秒"}]},
          {"matcher": {"id": "byName", "options": "stock_code"},   "properties": [{"id": "displayName", "value": "コード"}]},
          {"matcher": {"id": "byName", "options": "stock_name"},   "properties": [{"id": "displayName", "value": "銘柄名"}]},
          {"matcher": {"id": "byName", "options": "side"},         "properties": [{"id": "displayName", "value": "方向"}]},
          {"matcher": {"id": "byName", "options": "quantity"},     "properties": [{"id": "displayName", "value": "株数"}]},
          {"matcher": {"id": "byName", "options": "entry_price"},  "properties": [{"id": "displayName", "value": "エントリー価格"}]},
          {"matcher": {"id": "byName", "options": "exit_price"},   "properties": [{"id": "displayName", "value": "エグジット価格"}]}
        ]
      },
      "options": {"sortBy": [{"desc": true, "displayName": "エントリー"}], "footer": {"show": false}},
      "targets": [{"datasource": {"type": "mysql", "uid": "trade-mysql"}, "format": "table", "rawSql": "SELECT trade_date, DATE_FORMAT(entry_at, '%H:%i:%S') AS entry_at, DATE_FORMAT(exit_at, '%H:%i:%S') AS exit_at, duration_sec, stock_code, stock_name, side, quantity, entry_price, exit_price, pnl FROM daytrades WHERE trade_date = '$trade_date' AND stock_code IN ($stock_code) AND ('$side' = 'All' OR side = '$side') ORDER BY trade_date DESC, entry_at DESC LIMIT 500", "refId": "A"}]
    }
  ]
}
