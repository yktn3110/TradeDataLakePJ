{
  "id": null,
  "uid": "fx-v1",
  "title": "FX トレード分析",
  "tags": ["fx"],
  "timezone": "Asia/Tokyo",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "currency_pair",
        "type": "query",
        "label": "通貨ペア",
        "datasource": { "type": "mysql", "uid": "trade-mysql" },
        "query": "SELECT '__All__' AS __text, '%' AS __value UNION SELECT DISTINCT currency_pair, currency_pair FROM fx_trades ORDER BY 1",
        "includeAll": true,
        "allValue": "%",
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "総損益（円）",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "mysql", "uid": "trade-mysql" },
      "targets": [
        {
          "rawSql": "SELECT SUM(pnl_jpy) FROM fx_trades WHERE currency_pair LIKE '$currency_pair' AND trade_date BETWEEN '$__fromDate' AND '$__toDate'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyJPY",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "総損益（pips）",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "mysql", "uid": "trade-mysql" },
      "targets": [
        {
          "rawSql": "SELECT SUM(pnl_pips) FROM fx_trades WHERE currency_pair LIKE '$currency_pair' AND trade_date BETWEEN '$__fromDate' AND '$__toDate'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "トレード数",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "mysql", "uid": "trade-mysql" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FROM fx_trades WHERE currency_pair LIKE '$currency_pair' AND trade_date BETWEEN '$__fromDate' AND '$__toDate'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "勝率",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "mysql", "uid": "trade-mysql" },
      "targets": [
        {
          "rawSql": "SELECT ROUND(SUM(CASE WHEN pnl_jpy > 0 THEN 1 ELSE 0 END) / COUNT(*) * 100, 1) FROM fx_trades WHERE currency_pair LIKE '$currency_pair' AND trade_date BETWEEN '$__fromDate' AND '$__toDate'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "累積損益（円）",
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 8 },
      "datasource": { "type": "mysql", "uid": "trade-mysql" },
      "targets": [
        {
          "rawSql": "SELECT exit_at AS time, SUM(pnl_jpy) OVER (ORDER BY exit_at) AS 累積損益 FROM fx_trades WHERE currency_pair LIKE '$currency_pair' AND trade_date BETWEEN '$__fromDate' AND '$__toDate' ORDER BY exit_at",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyJPY", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "日別損益（円）",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 8 },
      "datasource": { "type": "mysql", "uid": "trade-mysql" },
      "targets": [
        {
          "rawSql": "SELECT CAST(trade_date AS DATETIME) AS time, SUM(pnl_jpy) AS 日別損益 FROM fx_trades WHERE currency_pair LIKE '$currency_pair' AND trade_date BETWEEN '$__fromDate' AND '$__toDate' GROUP BY trade_date ORDER BY trade_date",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyJPY", "custom": { "drawStyle": "bars", "fillOpacity": 80 } }
      }
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "通貨ペア別損益",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 8 },
      "datasource": { "type": "mysql", "uid": "trade-mysql" },
      "targets": [
        {
          "rawSql": "SELECT currency_pair, SUM(pnl_jpy) AS 損益 FROM fx_trades WHERE trade_date BETWEEN '$__fromDate' AND '$__toDate' GROUP BY currency_pair ORDER BY 損益 DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyJPY" } }
    },
    {
      "id": 8,
      "type": "table",
      "title": "トレード明細",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 8 },
      "datasource": { "type": "mysql", "uid": "trade-mysql" },
      "targets": [
        {
          "rawSql": "SELECT trade_date AS 日付, currency_pair AS 通貨ペア, side AS 売買, lot_size AS ロット, entry_price AS エントリー, exit_price AS エグジット, pnl_pips AS pips, pnl_jpy AS 損益円, swap AS スワップ FROM fx_trades WHERE currency_pair LIKE '$currency_pair' AND trade_date BETWEEN '$__fromDate' AND '$__toDate' ORDER BY entry_at DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": { "sortBy": [] },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "損益円" }, "properties": [{ "id": "unit", "value": "currencyJPY" }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] } }] }
        ]
      }
    }
  ],
  "links": [
    { "title": "CSVアップロード", "url": "http://localhost:8000", "targetBlank": true, "type": "link" }
  ]
}
